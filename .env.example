# All of these are optional for running locally: with none of them set,
# the app falls back to guest sign-in and a canned demo response so you can
# try the full retrieval + streaming + citations flow with zero setup.

# Anthropic API key used server-side only; never exposed to the client.
# Without it, chat responses fall back to a local demo response built from
# retrieval results instead of a real model-generated answer.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: overrides the default model (claude-sonnet-4-6).
ANTHROPIC_MODEL=claude-sonnet-4-6

# NextAuth
# Generate with: openssl rand -base64 32
# Without it, a local development secret is used automatically.
NEXTAUTH_SECRET=replace-with-a-random-secret
NEXTAUTH_URL=http://localhost:3000

# GitHub OAuth app credentials (create at github.com/settings/developers).
# Without these, sign-in falls back to a local guest session.
GITHUB_ID=your-github-oauth-client-id
GITHUB_SECRET=your-github-oauth-client-secret
